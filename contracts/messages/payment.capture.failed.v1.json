{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stockflow.local/contracts/messages/payment.capture.failed.v1.json",
  "title": "PaymentCaptureFailedV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "payment_id",
    "status",
    "reason_code",
    "reason_message"
  ],
  "properties": {
    "payment_id": {
      "type": "string",
      "pattern": "^pay_[a-z0-9_]+$",
      "maxLength": 64
    },
    "capture_id": {
      "type": "string",
      "pattern": "^cap_[a-z0-9_]+$",
      "maxLength": 64
    },
    "status": {
      "type": "string",
      "const": "failed"
    },
    "reason_code": {
      "type": "string",
      "enum": ["CAPTURE_FAILED", "PROVIDER_UNAVAILABLE", "PROCESSING_TIMEOUT"]
    },
    "reason_message": {
      "type": "string",
      "maxLength": 255
    }
  }
}
